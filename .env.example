# ============================================================
# NEVER commit .env — only commit this .env.example file
# Copy this file to .env and fill in your real values
# ============================================================

# ─── Image source ──────────────────────────────────────────────
# CI pushes ghcr.io/jason-tucker/squishybot:<sha> and floating :latest on main.
# Watchtower polls every 30s and restarts when this tag's digest changes.
# For local builds (rare), override to `squishybot:latest` and `docker compose up -d --build`.
BOT_IMAGE=ghcr.io/jason-tucker/squishybot:latest

# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# The single guild this bot serves
GUILD_ID=your_guild_id_here

# Environment
NODE_ENV=production

# ── Docker / Database ─────────────────────────────────────────────────────────
# Set a strong password here. Docker Compose uses this for both the
# postgres container and the DATABASE_URL connection string automatically.
# You do NOT need to set DATABASE_URL when using Docker Compose.
# STRONGLY RECOMMENDED: if left unset, compose falls back to a weak default
# ("squishybot_dev") and the bot logs a startup warning — the DB is reachable
# by every container on the shared botpanel-net, so set a strong value.
POSTGRES_PASSWORD=change_me_to_something_strong

# Local development only (non-Docker): uncomment and set this instead
# DATABASE_URL=postgresql://squishybot:squishybot_dev@localhost:5432/squishybot

# ── Sudo permissions ──────────────────────────────────────────────────────────
# Comma-separated Discord role/user IDs with bot-admin powers
SUDO_ROLE_IDS=
SUDO_USER_IDS=

# Bot owner — receives DMs on startup and uncaught errors
BOT_OWNER_ID=

# ── Voice channels ────────────────────────────────────────────────────────────
AUTO_VOICE_CATEGORY_ID=your_category_id_here
HUB_CHANNEL_IDS=hub_channel_id_1,hub_channel_id_2
VOICE_CLEANUP_DELAY_MS=90000

# ── Optional channels ─────────────────────────────────────────────────────────
LOG_CHANNEL_ID=
ADMIN_CHANNEL_ID=

# Staff approvals — posts go in this thread and ping this user
STAFF_APPROVAL_THREAD_ID=
STAFF_APPROVAL_PING_USER_ID=

# ── Future features ───────────────────────────────────────────────────────────
BIRTHDAY_CHANNEL_ID=
CLIPS_CHANNEL_ID=
FOOD_CHANNEL_ID=

# ── /report — files GitHub issues from inside Discord ─────────────────────────
# GITHUB_TOKEN: fine-grained PAT scoped to "Issues: Read & Write" on GITHUB_REPO.
# GITHUB_REPO:  "owner/name", e.g. jason-tucker/squishybot
# Both optional — /report replies with a friendly "not configured" error if missing.
# The bot owner (BOT_OWNER_ID above) reviews and approves each report via DM
# before the issue is filed.
GITHUB_TOKEN=
GITHUB_REPO=

# ── Uptime Kuma ───────────────────────────────────────────────────────────────
# UPTIME_KUMA_PUSH_URL=https://your-kuma-host/api/push/xxxxxxxxxx?status=up&msg=OK&ping=

# ── Command bus / Redis (botpanel integration) ────────────────────────────────
# BOTPANEL_RPC_SECRET: shared HMAC secret with botpanel for the Redis command
# bus (cmd.squishy.*) and cache-invalidate channel. Use a long random value
# (e.g. `openssl rand -hex 32`) and keep it IDENTICAL on both sides. If unset,
# the bot still boots but the command bus + cache-invalidation are DISABLED.
# SECURITY: this secret is the sole barrier protecting privileged RPC verbs
# (grant roles, manage channels, …). Treat it like a password and rotate it if
# it ever leaks.
BOTPANEL_RPC_SECRET=

# REDIS_URL: connection string for the shared event/command bus. Defaults to
# redis://redis:6379 (the botpanel compose stack) when unset. SECURITY: prefer
# an authenticated URL — redis://:STRONG_PASSWORD@redis:6379 — and enable
# `requirepass` on the Redis server so a co-tenant on the shared botpanel-net
# cannot read or inject bus traffic. The HMAC secret above prevents command
# forgery but not eavesdropping/DoS on an unauthenticated bus.
# REDIS_URL=redis://redis:6379

# ── Botpanel deep links ───────────────────────────────────────────────────────
# Website (botpanel) base URL used for the "do this on the website" links shown on
# slash command replies. Optional — defaults to https://bots.tucker.host.
PANEL_BASE_URL=https://bots.tucker.host
