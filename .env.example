# ============================================================
# NEVER commit .env — only commit this .env.example file
# Copy this file to .env and fill in your real values
# ============================================================

# Discord Bot
DISCORD_BOT_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# PostgreSQL
DATABASE_URL=postgresql://squishybot:squishybot_dev@localhost:5432/squishybot

# Environment
NODE_ENV=development

# The single guild this bot serves
GUILD_ID=your_guild_id_here

# Sudo permissions — comma-separated Discord IDs, or leave blank
SUDO_ROLE_IDS=role_id_1,role_id_2
SUDO_USER_IDS=user_id_1

# Voice hub configuration
AUTO_VOICE_CATEGORY_ID=your_category_id_here
HUB_CHANNEL_IDS=hub_channel_id_1,hub_channel_id_2
VOICE_CLEANUP_DELAY_MS=30000

# Optional: bot log channel and admin-only channel
LOG_CHANNEL_ID=
ADMIN_CHANNEL_ID=

# Future features — leave blank until those phases are built
STAFF_APPROVAL_CHANNEL_ID=
BIRTHDAY_CHANNEL_ID=
BLIPS_CHANNEL_ID=
FOOD_CHANNEL_ID=

# Uptime Kuma push monitor URL (optional)
# UPTIME_KUMA_PUSH_URL=https://your-kuma-host/api/push/xxxxxxxxxx?status=up&msg=OK&ping=
