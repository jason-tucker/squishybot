{
  "name": "squishybot",
  "version": "0.8.9",
  "description": "SquishyBot Discord bot",
  "main": "index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "node --max-old-space-size=4096 node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "deploy:commands": "node dist/bot/registerCommands.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio",
    "typecheck": "node --max-old-space-size=384 node_modules/typescript/bin/tsc --noEmit"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.2",
  "dependencies": {
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "ioredis": "^5.11.1",
    "postgres": "^3.4.9",
    "zod": "^4.4.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.2",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.23.1",
    "typescript": "^6.0.3"
  },
  "pnpm": {
    "overrides": {
      "ws": "^8.20.1"
    }
  }
}
