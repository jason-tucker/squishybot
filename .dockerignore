# Never bake secrets into the image
.env
.env.*

# Build artifacts (compiled inside Docker from source)
dist
*.tsbuildinfo

# Dev dependencies not needed in image context
node_modules

# Migration SQL files — schema is applied via drizzle-kit push at startup
src/db/migrations

# Runtime and local tooling
logs
*.log
.DS_Store

# VCS
.git
.github

# Docs and scripts not needed in the image
docs
README.md
CHANGELOG.md
CLAUDE.md
scripts/squishybot
scripts/clearCommands.ts

# drizzle local-dev config (Docker uses drizzle.docker.config.cjs)
drizzle.config.ts
