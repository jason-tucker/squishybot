# Never bake secrets into the image
.env
.env.*

# Build artifacts (compiled inside Docker from source)
dist
*.tsbuildinfo

# Dev dependencies not needed in image context
node_modules

# NOTE: src/db/migrations is intentionally NOT ignored — the committed .sql
# migrations must be in the build context so they can be copied into the image
# for the startup migrate runner.

# Runtime and local tooling
logs
*.log
.DS_Store

# VCS
.git
.github

# Docs and scripts not needed in the image
docs
README.md
CHANGELOG.md
CLAUDE.md
scripts/squishybot
scripts/clearCommands.ts

# drizzle-kit config is only used for local dev (generate/check/studio); the
# image's migrate runner reads the migrations folder directly.
drizzle.config.ts
